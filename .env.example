# GitHub Secrets Migrator - Environment Configuration

# GitHub Personal Access Token (used for both source and target if individual tokens not provided)
GITHUB_TOKEN=ghp_your_token_here

# Organization and Repository Configuration
# Source organization name
SOURCE_ORG=source-org

# Source repository name (required for both repo-to-repo and org-to-org migrations)
SOURCE_REPO=source-repo

# Target organization name
TARGET_ORG=target-org

# Target repository name (required for repo-to-repo migration, optional for org-to-org)
TARGET_REPO=target-repo

# Optional: Individual PATs for source and target (if different from GITHUB_TOKEN)
# SOURCE_PAT=ghp_source_token_here
# TARGET_PAT=ghp_target_token_here

# Optional: Custom GitHub API endpoints (for GHEC Data Residency, GHES, etc.)
# Default: https://api.github.com
# SOURCE_ENDPOINT=https://api.github.com
# TARGET_ENDPOINT=https://api.github.com

# Examples for different GitHub deployments:
# - GHEC Data Residency: https://api.<INSTANCE>.ghe.com (e.g., https://api.nicklegan.ghe.com)
# - GitHub Enterprise Server: https://github.example.com/api/v3

# Logging and Behavior Flags
# VERBOSE=true
# SKIP_ENVS=true
